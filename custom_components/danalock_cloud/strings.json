{
    "config": {
      "step": {
        "user": {
          "title": "Danalock Cloud Credentials",
          "description": "Enter your Danalock account username and password. This integration communicates via the Danalock Cloud API.\n\n**Important:** Ensure Two-Factor Authentication (2FA) is **disabled** on this account and that it is the **owner** account for the lock and bridge.",
          "data": {
            "username": "[%key:common::config_flow::data::username%]",
            "password": "[%key:common::config_flow::data::password%]"
          }
        }
      },
      "error": {
        "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
        "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
        "unknown": "[%key:common::config_flow::error::unknown%]"
      },
      "abort": {
        "already_configured": "[%key:common::config_flow::abort::already_configured_account%]"
      }
    },
    "options": {
      "step": {
          "init": {
              "title": "Danalock Cloud Options",
              "description": "Adjust Danalock Cloud integration options.",
              "data": {
                  "update_interval": "Update Interval (Minutes)"
              }
          }
      }
    },
    "services": {
        "refresh_devices": {
            "name": "Refresh Devices",
            "description": "Forces an immediate refresh of all Danalock device states and battery levels from the cloud API for all configured accounts."
        }
    },
    "entity": {
        "lock": {
            "state_attributes": {}
        },
        "sensor": {
            "battery": {
                "name": "Battery"
            }
        }
    }
}
